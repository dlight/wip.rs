#!/bin/bash

shopt -s lastpipe

if [[ $(git rev-parse --is-inside-work-tree 2> /dev/null) != true ]]; then
    exit
fi

myrepo="$(git rev-parse --show-toplevel)"

count=0

"$(dirname "$0")"/wip-list | while read pid dir; do
    cd "$dir"

    root="$(git rev-parse --show-toplevel 2> /dev/null)"

    if [[ $root == $myrepo ]]; then
        count=$((count + 1))
    fi
done

if [[ $count -eq 1 ]]; then
    echo "wipd"
elif [[ $count -gt 1 ]]; then
    echo "(error: $count wipd instances)"
    exit 1
fi
