#!/bin/bash

# If the current repository is clean, prints the current commit hash, otherwise
# prints the hash of the wip commit (calling `git wip` first to ensure it
# exists)

if [[ $(git status --porcelain) ]]; then
    current_branch="$(git branch --show-current)"

    git wip 2>&1 | sed '/no changes/d'

    git rev-parse "refs/wip/$current_branch"

else
    git rev-parse HEAD
fi
