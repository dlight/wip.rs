#!/bin/bash

if [[ $#  -lt 2 ]]; then
    less "$0"
fi

path="$(realpath "$1")"

target="$2"

if [[ ! -f "$path" ]]; then
    echo "Error: '$1' is not a file" >&2
    exit 1
fi

cd "$(dirname "$path")"

cd "$(git rev-parse --show-toplevel)"

trapfn() {
    rm -f "$GIT_INDEX_FILE"
}

export GIT_INDEX_FILE="$(mktemp)"

trap trapfn ERR EXIT INT HUP QUIT TERM

git read-tree --empty

cargo run --quiet --bin wip-influences-build "$path" "$target" | while read file; do
    git add "$file"
done

new_tree="$(git write-tree)"

echo "$new_tree"
