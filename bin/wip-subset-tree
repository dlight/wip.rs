#!/bin/bash

set -e
set -o pipefail

if [[ $#  -lt 2 ]]; then
    less "$0"
fi

path="$(realpath "$1")"

target="$2"

if [[ ! -f "$path" ]]; then
    echo "Error: '$1' is not a file" >&2
    exit 1
fi

# go to target git repo so we can do git read-tree
cd "$(dirname "$path")"
git_repo="$(git rev-parse --show-toplevel)"
cd "$git_repo"

trapfn() {
    rm -f "$GIT_INDEX_FILE"
}

export GIT_INDEX_FILE="$(mktemp)"

trap trapfn ERR EXIT INT HUP QUIT TERM

git read-tree --empty

# get back so that we can run wip-influences-build
cd "$(dirname "$0")"
cd "$(git rev-parse --show-toplevel)"

output="$(cargo run --quiet --bin wip-influences-build "$path" "$target")"

# back to target git repo so we can run git add
cd "$git_repo"

echo "$output" | while read file; do
    git add "$file"
done

new_tree="$(git write-tree)"

echo "$new_tree"
