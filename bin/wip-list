#!/bin/bash

shopt -s lastpipe

# It would be cool to list all wipd instances that are running in the current
# repo, to see if there are more than one.

process_all() {
    local pids="$@"

    local total=0

    if [[ -z $count ]]; then
        pwdx $pids
    else
        pwdx $pids | sed 's/://' | while read pid dir; do
            total=$((total + 1))
        done

        echo $total
    fi
}

pids="$(pgrep --delimiter=' ' wip-fd41eca378)"

if [[ -n $pids ]]; then
    process_all $pids
fi
